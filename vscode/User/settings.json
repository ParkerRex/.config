  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "editor.formatOnSave": true,
  "eslint.enable": true,
  "remote.SSH.remotePlatform": {
    "sandbox.4y3jx9.csb": "linux",
    "84d20133-a2f5-5704-bd38-c2a7f2afd371": "linux"
  },
  "github.copilot.enable": {
    "*": true
  },
  "editor.inlineSuggest.enabled": true,
  "github.copilot.inlineSuggest.enable": true,
  "accessibility.verbosity.inlineChat": false,
  "scm.defaultViewMode": "tree",
  "scm.autoReveal": false,
  "terminal.integrated.allowChords": false,
  "search.decorations.badges": false,
  "window.closeWhenEmpty": true,
  "editor.scrollbar.horizontalScrollbarSize": 0,
  "editor.scrollbar.verticalScrollbarSize": 6,
  "search.smartCase": true,
  "search.exclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.next/**": true,
    "**/.turbo/**": true,
    "**/.cache/**": true
  },
  "scm.showActionButton": false,
  "diffEditor.renderSideBySide": false,
  "workbench.editor.editorActionsLocation": "default",
  "workbench.editor.showTabs": "multiple",
  "workbench.editor.enablePreview": true,
  "workbench.tree.enableStickyScroll": false,
  "workbench.tree.renderIndentGuides": "none",
  "workbench.tree.indent": 8,
  "explorer.compactFolders": false,
  "explorer.decorations.badges": false,
  "editor.codeLens": true,
  "editor.matchBrackets": "never",
  "editor.selectionHighlight": false,
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.suggestOnTriggerCharacters": false,
  "git.closeDiffOnOperation": true,
  "gitlens.graph.layout": "editor",
  "git.replaceTagsWhenPull": true,
  "gitlens.views.branches.files.icon": "status",
  "inlineChat.accessibleDiffView": "on",
  "inlineChat.lineEmptyHint": true,
  "workbench.preferredLightColorTheme": "One Hunter Theme Light",
  "workbench.preferredDarkColorTheme": "One Hunter Theme",
  "remote.SSH.defaultExtensions": [],
