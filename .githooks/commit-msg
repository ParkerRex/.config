#!/usr/bin/env bash

set -euo pipefail

message_file="${1:?commit message file is required}"
header="$(head -n 1 "$message_file" | tr -d '\r')"

if [[ -z "$header" ]]; then
    echo "Empty commit message." >&2
    exit 1
fi

case "$header" in
    Merge\ *|Revert\ *|fixup!\ *|squash!\ *)
        exit 0
        ;;
esac

pattern='^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)(\([a-z0-9][a-z0-9-]*\))?(!)?: .+$'

if ! [[ "$header" =~ $pattern ]]; then
    cat >&2 <<'EOF'
Commit message must use Conventional Commits.

Expected:
  type(scope): summary

Examples:
  docs(readme): document the symlink bootstrap flow
  fix(nvim): remove cloak from env files
  chore(git): install repo-local commit hooks
EOF
    exit 1
fi
